# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git — it is already in .gitignore.

# ── Anthropic API ──────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY

# ── Database ───────────────────────────────────────────────────
# Local development: keep this as-is (SQLite file, no setup needed)
DATABASE_URL="file:./dev.db"
#
# Production (Vercel Postgres): replace with the connection string
# Vercel provides when you add a Postgres database to your project.
# DATABASE_URL="postgresql://user:pass@host.neon.tech/dbname?sslmode=require"

# ── AI mode ────────────────────────────────────────────────────
# true  = mock destinations (free, good for testing)
# false = real Claude AI (requires ANTHROPIC_API_KEY with credits)
MOCK_AI=true
NEXT_PUBLIC_MOCK_AI=true
